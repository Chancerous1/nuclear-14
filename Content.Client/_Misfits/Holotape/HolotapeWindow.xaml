<DefaultWindow xmlns="https://spacestation14.io"
               Title="TERMINAL"
               MinSize="480 380"
               SetSize="520 500">
    <!-- Green-on-black Vault-Tec ASCII terminal aesthetic -->
    <!-- Background and separator styling applied in code-behind -->
    <PanelContainer Name="BackgroundPanel" VerticalExpand="True" HorizontalExpand="True">
        <BoxContainer Orientation="Vertical" Margin="12 8 12 8" SeparationOverride="6">
            <!-- Terminal header -->
            <Label Name="HeaderLabel"
                   Text="ROBCO INDUSTRIES (TM) TERMLINK PROTOCOL"
                   FontColorOverride="#33FF33"
                   StyleClasses="monospace"
                   HorizontalAlignment="Center" />
            <!-- Separator line -->
            <PanelContainer Name="SepTop" MinHeight="1" HorizontalExpand="True" />

            <!-- Tab buttons row (visible when terminal has notebook or link ports) -->
            <BoxContainer Name="TabBar" Orientation="Horizontal" SeparationOverride="4" Visible="False">
                <Button Name="DataTabButton" Text="[ DATA ]" MinWidth="80" />
                <Button Name="NotesTabButton" Text="[ NOTES ]" MinWidth="80" />
                <!-- #Misfits Add - Links tab button for device link port controls -->
                <Button Name="LinksTabButton" Text="[ LINKS ]" MinWidth="80" Visible="False" />
            </BoxContainer>

            <!-- ═══ DATA TAB content ═══ -->
            <BoxContainer Name="DataPanel" Orientation="Vertical" VerticalExpand="True" SeparationOverride="6">
                <!-- Entry title -->
                <RichTextLabel Name="EntryTitleLabel"
                               StyleClasses="monospace"
                               HorizontalExpand="True" />
                <!-- Separator line -->
                <PanelContainer Name="SepMid" MinHeight="1" HorizontalExpand="True" />
                <!-- Scrollable content area -->
                <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                    <RichTextLabel Name="ContentLabel"
                                   StyleClasses="monospace"
                                   HorizontalExpand="True" />
                </ScrollContainer>
                <!-- Footer -->
                <PanelContainer Name="SepBot" MinHeight="1" HorizontalExpand="True" />
                <Label Text="[END OF FILE]"
                       FontColorOverride="#1a5c1a"
                       StyleClasses="monospace"
                       HorizontalAlignment="Center" />
            </BoxContainer>

            <!-- ═══ NOTES TAB content (hidden by default) ═══ -->
            <BoxContainer Name="NotesPanel" Orientation="Vertical" VerticalExpand="True" SeparationOverride="4" Visible="False">
                <!-- Scrollable note list -->
                <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                    <BoxContainer Name="NotesList" Orientation="Vertical" SeparationOverride="4"
                                  HorizontalExpand="True" />
                </ScrollContainer>
                <!-- Separator before input area -->
                <PanelContainer Name="SepNotes" MinHeight="1" HorizontalExpand="True" />
                <!-- Note text input - author name is auto-assigned from character name server-side -->
                <LineEdit Name="NoteInput"
                          PlaceHolder="Type your note here..."
                          HorizontalExpand="True" />
                <!-- Submit button -->
                <Button Name="SubmitNoteButton" Text="[ SUBMIT NOTE ]" HorizontalAlignment="Center" />
            </BoxContainer>

            <!-- ═══ LINKS TAB content (hidden by default) ═══ -->
            <!-- #Misfits Add - Scrollable list of device link port toggle buttons -->
            <BoxContainer Name="LinksPanel" Orientation="Vertical" VerticalExpand="True" SeparationOverride="4" Visible="False">
                <Label Name="LinksHeaderLabel"
                       Text="CONNECTED SYSTEMS"
                       FontColorOverride="#33FF33"
                       StyleClasses="monospace"
                       HorizontalAlignment="Center" />
                <PanelContainer Name="SepLinks" MinHeight="1" HorizontalExpand="True" />
                <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                    <BoxContainer Name="LinksList" Orientation="Vertical" SeparationOverride="6"
                                  HorizontalExpand="True" />
                </ScrollContainer>
            </BoxContainer>
        </BoxContainer>
    </PanelContainer>
</DefaultWindow>
